وعدّل الـ **Dockerfile** كمان — احذف السطر الأخير `CMD` خليه هيك:
```
FROM python:3.11-slim

WORKDIR /app

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ ./backend/
COPY frontend/ ./frontend/

WORKDIR /app/backend
